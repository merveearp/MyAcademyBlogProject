@model List<ResultCategoryDto>
@{
    ViewData["Title"] = "Index";
	Layout = "~/Areas/Admin/Views/Admin/AdminLayout.cshtml";


	int count = 0;
}

<!-- basic table  Start -->
<div class="pd-20 card-box mb-30">
	<div class="clearfix mb-20">
		<div class="pull-left">
			<h2 class="text-blue h2">Kategoriler</h2>
			
		</div>
		
	</div>
	<table class="table">
		<thead>
			<tr>
				<th>#</th>
				<th>Kategori Adı</th>
				<th>İşlemler</th>
			</tr>

		</thead>
		<tbody>


			@foreach (var item in Model)
			{
				count++;
				<tr>
					<th>@count</th>
					<td>@item.CategoryName</td>
					<td>

						<a href="/Admin/Category/DeleteCategory/@item.Id" class="btn btn-danger">Sil</a>
						<a href="/Admin/Category/UpdateCategory/@item.Id" class="btn btn-info">Güncelle</a>

					</td>
				</tr>
			}
		</tbody>
	</table>
	<a href="/Admin/Category/CreateCategory" class="btn btn-success">Yeni Kategori Oluştur</a>
	
</div>
<!-- basic table  End -->
