@model List<ResultCommentDto>
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Admin/AdminLayout.cshtml";
}

<h1>Yorumlar</h1>

@{
    int count = 0;
}
<table class="table table-bordered table-hover">
    <tr>
        <th>#</th>
        <th>Blog Id</th>
        <th>Yorum İçeriği</th>
        <th>İşlemler</th>
    </tr>

    @foreach (var item in Model)
    {
        count++;
        <tr>
            <th>@count</th>
            <th>@item.BlogId</th>
            <th>@item.Content</th>          
           
            <td>

                <a href="/Admin/Comment/DeleteComment/@item.Id" onclick="return confirm('Bu öğeyi kalıcı olarak silmek istediğinizden emin misiniz?')" class="btn btn-danger">Sil</a>
                <a href="/Admin/Comment/UpdateComment/@item.Id" class="btn btn-info">Güncelle</a>

            </td>
        </tr>
    }

</table>
<a href="/Admin/Blog/CreateBlog" class="btn btn-success">Yeni Yorum Oluştur</a>
